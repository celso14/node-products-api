generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Providers {
  id    Int       @id @default(autoincrement())
  email String    @unique
  phone String
  items Products?

  @@map("providers")
}

model Products {
  id         Int       @id @default(autoincrement())
  tagName    String
  price      Decimal
  product    Providers @relation(fields: [providerId], references: [id])
  providerId Int       @unique

  @@map("products")
}
